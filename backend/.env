# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=starlinkpro
DB_USER=postgres
DB_PASSWORD=StarLink@2026

# SQLite fallback (used if PG unavailable)
SQLITE_PATH=./data/starlink.db

# JWT
JWT_SECRET=starlink-pro-super-secret-jwt-key-2026
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=starlink-refresh-secret-2026
JWT_REFRESH_EXPIRES_IN=7d

# API Keys
ADMIN_API_KEY=SLPRO-ADMIN-KEY-2026
INTERNAL_API_KEY=SLPRO-INTERNAL-2026

# CelesTrak
CELESTRAK_URL=https://celestrak.org/NORAD/elements/gp.php
CELESTRAK_GROUP=starlink
TLE_REFRESH_INTERVAL_MS=7200000

# Monitoring
HEALTH_CHECK_INTERVAL_MS=60000
ALERT_EMAIL=admin@starlinkpro.local
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
ERROR_LOG_FILE=./logs/error.log
